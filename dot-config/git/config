[user]
name  = Karl Meakin
email = karlwfmeakin@gmail.com
signingkey = ~/.ssh/id_ed25519.pub

# Sign commits
[commit]
gpgSign = true

# Use SSH keys for commit signing
[gpg]
format = ssh

[sendemail]
smtpserver     = mail.arm.com
smtpserverport = 25
smtpauth       = none
smtpencryption = none

[push]
# Set upstream branch automatically when pushing
autoSetupRemote = true

[core]
pager = delta

[interactive]
diffFilter = delta

[delta]
side-by-side = true

[format]
pretty=fancy

[pretty]
fancy=\
%C(reset)Commit: %C(red)%h %d%n\
%C(reset)Author: %C(blue)%an (%ae)%C(reset)%n\
%C(reset)Date:   %C(yellow)%cd (%cr)%C(reset)%n\
%C(reset)%B%n\

[alias]
fancy-log = log --decorate --graph --pretty=fancy
